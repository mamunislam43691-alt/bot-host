# Server
PORT=3000
NODE_ENV=production

# Security — CHANGE THESE before deploying!
JWT_SECRET=change-this-to-a-long-random-string
# First admin account password (auto-created on first boot if ADMIN_USERNAME set)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Data storage location (Railway: use a mounted volume path like /data)
DATA_DIR=./data

# Optional: max upload size in MB
MAX_UPLOAD_MB=50

# Optional: prevent new public signups (set to "true" to disable self-registration)
DISABLE_SIGNUP=false
